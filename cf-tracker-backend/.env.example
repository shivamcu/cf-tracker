# CF Tracker Backend Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PORT=5001

# MongoDB Connection String
# For local development: mongodb://localhost:27017/cf-tracker
# For MongoDB Atlas (cloud): mongodb+srv://username:password@cluster.mongodb.net/cf-tracker
MONGO_URI=mongodb://localhost:27017/cf-tracker

# JWT Secret Key
# Generate a strong random string for production
# Example: openssl rand -base64 32
JWT_SECRET=your-super-secret-key-change-this-in-production
